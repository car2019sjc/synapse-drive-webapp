# Variáveis usadas APENAS no build de produção (pnpm build).
# Para dev local, o Vite faz proxy automático /api → localhost:3000 (vite.config.ts).
#
# IMPORTANTE: estas variáveis são EMBUTIDAS no bundle JS gerado.
# Se você mudar a URL da API, precisa REBUILDAR e RE-UPLOAD no Netlify.

VITE_API_BASE_URL=https://api.drive.synapseia.com.br
VITE_APP_NAME=Synapse Drive
VITE_SUPPORT_EMAIL=suporte@synapseia.com.br
