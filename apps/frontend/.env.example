# URL base da API (sem barra final).
# Em dev local Vite faz proxy /api → backend automaticamente; pode deixar vazio.
# Em produção (Netlify) defina como o domínio público do backend, ex:
#   VITE_API_BASE_URL=https://api.drive.synapseia.com.br
VITE_API_BASE_URL=

# Nome amigável da plataforma exibido na UI.
VITE_APP_NAME=Synapse Drive

# E-mail de contato exibido em rodapés / mensagens de erro.
VITE_SUPPORT_EMAIL=suporte@synapseia.com.br
