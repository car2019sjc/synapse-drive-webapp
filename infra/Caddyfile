# =============================================================================
# Caddy 2 - Reverse proxy + SSL automático (Let's Encrypt) para o backend.
#
# Modo de operação ESPECIAL desta VPS:
#   A porta 80 do host está OCUPADA por outro nginx (synapse-lite-nginx).
#   Por isso, Caddy escuta APENAS em 443 e usa TLS-ALPN-01 challenge
#   (faz a validação do Let's Encrypt dentro do TLS handshake na 443).
#
#   - Porta 80 do host: NÃO usada por este Caddy (livre pro outro nginx)
#   - Porta 443 do host: usada exclusivamente por este Caddy
#   - HTTP-01 challenge: desativado (porta 80 indisponível)
#   - TLS-ALPN-01 challenge: ativo (Let's Encrypt valida via 443)
#   - Sem redirect HTTP -> HTTPS (a API só responde em HTTPS)
# =============================================================================

{
	# Email para registro Let's Encrypt e alertas de expiração de cert.
	email {$ADMIN_EMAIL}

	# Sem redirect HTTP->HTTPS (Caddy nao tem 80 nesta VPS).
	auto_https disable_redirects

	# Logs estruturados em JSON.
	log {
		output stdout
		format json
		level INFO
	}
}

# -----------------------------------------------------------------------------
# api.drive.synapseia.com.br -> backend Fastify (interno, rede Docker)
# -----------------------------------------------------------------------------
api.drive.synapseia.com.br {
	# Forca Let's Encrypt a usar APENAS TLS-ALPN-01 (porta 443).
	# HTTP-01 nao funciona aqui porque a porta 80 esta tomada por outro proxy.
	tls {
		protocols tls1.2 tls1.3
		issuer acme {
			disable_http_challenge
		}
	}

	# Cabeçalhos de segurança
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "DENY"
		Referrer-Policy           "strict-origin-when-cross-origin"
		Permissions-Policy        "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# Compressão
	encode gzip zstd

	# Limite de tamanho de upload (10 MB do firmware + folga p/ multipart)
	request_body {
		max_size 12MB
	}

	# Reverse proxy para o backend (na rede Docker interna)
	reverse_proxy synapse-backend:3000 {
		transport http {
			read_timeout 60s
			write_timeout 60s
			dial_timeout 5s
		}

		# Repassa o IP real do cliente
		header_up X-Real-IP        {remote_host}
		header_up X-Forwarded-For  {remote_host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}

	log {
		output stdout
		format json
	}
}
