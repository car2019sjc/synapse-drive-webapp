# =============================================================================
# Synapse Drive WebApp - Variáveis de ambiente para o docker-compose
#
# 1) Copie este arquivo para .env (mesmo diretório)
# 2) Preencha TODOS os campos obrigatórios marcados com [OBRIGATÓRIO]
# 3) NUNCA comite o arquivo .env final (ele está no .gitignore)
# =============================================================================

# ----- PostgreSQL DEDICADO (container Docker isolado) -----
POSTGRES_DB=synapse_drive
POSTGRES_USER=synapse_app
# [OBRIGATÓRIO] Gere com: openssl rand -base64 24 | tr -dc 'A-Za-z0-9' | head -c 28
POSTGRES_PASSWORD=

# ----- JWT -----
# [OBRIGATÓRIO] Gere com: openssl rand -hex 32
# Mínimo 32 caracteres
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ----- CORS -----
# Origens permitidas (frontend). Separe por vírgula. SEM barra final.
# Em prod com Netlify + domínio custom:
CORS_ORIGINS=https://drive.synapseia.com.br,https://dashing-llama-8650c6.netlify.app

# ----- Rate limit -----
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# ----- Caddy (reverse proxy + SSL automatico) -----
# Email usado pelo Let's Encrypt (avisos de expiracao). [OBRIGATÓRIO]
ADMIN_EMAIL=admin@synapseia.com.br

# Portas que o Caddy escuta no host. Padrão 80/443.
# Se voce ja tem outro proxy ocupando essas portas, troque para 8080/8443
# (mas SSL automatico vai precisar de redirect manual do seu proxy externo).
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ----- Seed do admin (usado pelo prisma/seed.ts) -----
# O ADMIN_EMAIL acima e usado pelo seed tambem (login no painel).
# [OBRIGATÓRIO] Senha do admin inicial (minimo 8 chars).
ADMIN_PASSWORD=
ADMIN_NAME=Administrador
